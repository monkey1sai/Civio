# Civio environment template
# Copy to .env and fill in actual values. NEVER commit .env.

# ─── Infrastructure ────────────────────────────────────────────
POSTGRES_DB=civio
POSTGRES_USER=civio
POSTGRES_PASSWORD=change_me_min_16_chars

REDIS_PASSWORD=change_me_min_16_chars

RABBITMQ_USER=civio
RABBITMQ_PASSWORD=change_me_min_16_chars

# ─── Cloud API ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://civio:change_me_min_16_chars@postgres:5432/civio
REDIS_URL=redis://:change_me_min_16_chars@redis:6379/0
RABBITMQ_URL=amqp://civio:change_me_min_16_chars@rabbitmq:5672/civio

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=replace_with_random_48_byte_base64
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# OTP
OTP_TTL_SEC=300
OTP_LENGTH=6

# SIP
SIP_DOMAIN_SUFFIX=sip.civio.local
OPENSIPS_AUTH_SHARED_SECRET=replace_with_random_32_byte_hex

# ─── Edge (per-community) ──────────────────────────────────────
EDGE_COMMUNITY_ID=00000000-0000-0000-0000-000000000001
EDGE_PUBLIC_IP=127.0.0.1
EDGE_SYNC_SHARED_SECRET=replace_with_random_32_byte_hex
ASTERISK_AMI_USER=civio_ami
ASTERISK_AMI_SECRET=change_me_min_16_chars
CLOUD_API_URL=http://civio-cloud-api:8000
CLOUD_RABBITMQ_URL=amqp://civio:change_me_min_16_chars@rabbitmq:5672/civio

# ─── Payment providers (leave empty in local dev) ──────────────
PAYMENT_PROVIDER=ecpay
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=

NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=

# ─── SMS gateway (for OTP) ─────────────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1234567890

# ─── Push notifications ────────────────────────────────────────
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON_PATH=./secrets/fcm-service-account.json
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.civio.resident
APNS_KEY_PATH=./secrets/apns-auth-key.p8

# ─── Observability ─────────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=

# ─── Environment ───────────────────────────────────────────────
ENV=local
